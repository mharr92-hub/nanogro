NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=evidence
ADMIN_PASSWORD=change-this-before-production

# Numero de WhatsApp del equipo comercial, en formato internacional y solo digitos.
# Ejemplo: 50712345678 (codigo de pais + numero, sin +, sin espacios, sin guiones).
#
# OBLIGATORIO EN PRODUCCION. Sin el, los enlaces de WhatsApp saldrian como
# "wa.me/?text=..." (sin destinatario), que abre el selector de contactos del propio
# usuario en vez de escribir a tu equipo: cada lead que toca ese boton se pierde.
# Por eso, si esta vacio, la aplicacion OCULTA los botones de WhatsApp en lugar de
# publicar un enlace roto.
#
# NEXT_PUBLIC_ es el que usan los botones del navegador; NANO_GRO_ lo usa el servidor.
# Configura los dos con el mismo numero.
NEXT_PUBLIC_WHATSAPP_NUMBER=
NANO_GRO_WHATSAPP_NUMBER=
